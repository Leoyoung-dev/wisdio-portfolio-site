---
import Layout from '../../layouts/Layout.astro';
import videos from '../../data/videos.json';
---

<Layout title="视频作品 - 刘扬">
  <main class="page-body">
    <article class="paper">
      <header class="page-header">
        <span class="page-label">Works</span>
        <h1 class="page-title">视频作品</h1>
        <p class="page-desc">产品宣传视频、动效设计与内容创作</p>
      </header>

      <section class="section">
        <div class="video-grid">
          {videos.map((video) => (
            <div class="video-card">
              {video.video ? (
                <div class="video-player">
                  <video controls preload="metadata" poster={video.thumbnail} style="width: 100%; display: block; background: #000;">
                    <source src={video.video} type="video/mp4" />
                    <p>您的浏览器不支持视频播放，请<a href={video.video} download>下载观看</a></p>
                  </video>
                </div>
              ) : (
                <a href={video.url} target="_blank" rel="noopener noreferrer" class="video-link-wrapper">
                  <div class="video-thumbnail">
                    {video.thumbnail ? (
                      <img src={video.thumbnail} alt={video.title} loading="lazy" />
                    ) : (
                      <div class="placeholder">▶</div>
                    )}
                    <div class="play-overlay">
                      <span class="play-icon">▶</span>
                    </div>
                  </div>
                </a>
              )}
              <div class="video-info">
                <span class="video-category">{video.category}</span>
                <h2 class="video-title">{video.title}</h2>
                <p class="video-desc">{video.description}</p>
                <div class="video-meta">
                  <span class="video-date">{video.date}</span>
                  {!video.video && (
                    <a href={video.url} target="_blank" rel="noopener noreferrer" class="video-external-link">
                      查看完整内容 →
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    </article>
  </main>
</Layout>

<style>
  .paper {
    max-width: 780px;
    margin: 0 auto;
    background: #fff;
    min-height: 100vh;
  }

  .page-header {
    padding: 70px 50px 40px;
    border-bottom: 1px solid #e0e0e0;
  }

  .page-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: #999;
    margin-bottom: 12px;
    display: block;
  }

  .page-title {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 8px;
  }

  .page-desc {
    font-size: 15px;
    color: #666;
    font-weight: 400;
  }

  .section {
    padding: 40px 50px;
  }

  .video-grid {
    display: flex;
    flex-direction: column;
    gap: 50px;
  }

  .video-card {
    border-bottom: 1px solid #f0f0f0;
    padding-bottom: 40px;
  }

  .video-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .video-player {
    width: 100%;
    margin-bottom: 20px;
    background: #000;
  }

  .video-player video {
    width: 100%;
    display: block;
  }

  .video-link-wrapper {
    display: block;
  }

  .video-thumbnail {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #f5f5f5;
    overflow: hidden;
    position: relative;
    border: 1px solid #e0e0e0;
  }

  .video-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    transition: filter 0.3s;
  }

  .video-card:hover .video-thumbnail img {
    filter: grayscale(0%);
  }

  .play-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .video-card:hover .play-overlay {
    opacity: 1;
  }

  .play-icon {
    font-size: 48px;
    color: #fff;
  }

  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: #ccc;
  }

  .video-info {
    padding: 0;
  }

  .video-category {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #c9463d;
    margin-bottom: 8px;
    display: block;
    font-weight: 500;
  }

  .video-title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 10px;
    color: #1a1a1a;
  }

  .video-desc {
    font-size: 14px;
    color: #666;
    line-height: 1.7;
    margin-bottom: 15px;
  }

  .video-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .video-date {
    font-size: 12px;
    color: #999;
    font-family: Georgia, serif;
  }

  .video-external-link {
    font-size: 12px;
    color: #c9463d;
    font-weight: 500;
  }

  .video-external-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .page-header {
      padding: 60px 25px 30px;
    }

    .section {
      padding: 30px 25px;
    }

    .video-grid {
      gap: 35px;
    }

    .video-card {
      padding-bottom: 30px;
    }
  }
</style>