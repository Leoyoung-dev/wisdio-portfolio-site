---
import Layout from '../../layouts/Layout.astro';
import videos from '../../data/videos.json';
---

<Layout title="视频作品 - 刘扬">
  <main class="page-body">
    <div class="page-container">
      <div class="page-header">
        <h1 class="page-title">视频作品</h1>
        <p class="page-desc">产品宣传视频、Demo 演示与创意内容</p>
      </div>

      <div class="grid">
        {videos.map((video) => (
          <a href={video.url} target="_blank" rel="noopener noreferrer" class="card">
            <div class="thumbnail-wrapper">
              {video.thumbnail ? (
                <img src={video.thumbnail} alt={video.title} class="thumbnail" loading="lazy" />
              ) : (
                <div class="thumbnail-placeholder">🎬</div>
              )}
            </div>
            <div class="card-body">
              <span class="card-date">{video.date}</span>
              <h2 class="card-title">{video.title}</h2>
              <p class="card-desc">{video.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  .page-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 6rem 2rem 4rem;
  }

  .page-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 0.75rem;
  }

  .page-desc {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.45);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s;
    background: rgba(255, 255, 255, 0.02);
  }

  .card:hover {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-4px);
  }

  .thumbnail-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #111;
  }

  .thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    transition: opacity 0.3s, transform 0.5s;
  }

  .card:hover .thumbnail {
    opacity: 1;
    transform: scale(1.03);
  }

  .thumbnail-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    background: #111;
    color: rgba(255, 255, 255, 0.3);
  }

  .card-body {
    padding: 1.25rem 1.5rem;
  }

  .card-date {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.35);
    font-family: 'Inter', monospace;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0.4rem 0 0.6rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.4;
  }

  .card-desc {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
