---
import Layout from '../layouts/Layout.astro';
---

<Layout title="刘扬 - 个人作品集 | Wisdio Portfolio">
  <main class="landing">
    <div class="hero">
      <div class="hero-content">
        <h1 class="title">你好，我是刘扬</h1>
        <p class="subtitle">产品经理 / 创作者 / 独立开发者</p>
        <p class="bio">
          致力于探索 AI 与产品的结合点，打造提升效率的学习工具，并热衷于内容创作与传播。
        </p>

        <div class="action-links">
          <a href="/resume" class="btn primary-btn">查看简历</a>
          <a href="/showcase/videos" class="btn secondary-btn">视频作品</a>
          <a href="/showcase/articles" class="btn secondary-btn">发表文章</a>
        </div>
      </div>
      <div class="hero-image-wrapper">
         <div class="model-image"></div>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Local styling specific to landing page */
  .landing {
    min-height: 100vh;
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
    color: #f8fafc;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    padding: 2rem;
  }

  /* Decorative background elements */
  .landing::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
    top: -200px;
    left: -200px;
    z-index: 1;
  }
  
  .landing::after {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.15) 0%, transparent 70%);
    bottom: -150px;
    right: -100px;
    z-index: 1;
  }

  .hero {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 4rem;
    max-width: 1100px;
    width: 100%;
    z-index: 10;
  }

  @media (min-width: 768px) {
    .hero {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    animation: fadeUp 1s ease-out forwards;
    opacity: 0;
  }

  .title {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.2;
    background: linear-gradient(to right, #e2e8f0, #94a3b8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: 2px;
  }

  .subtitle {
    font-size: 1.5rem;
    font-weight: 500;
    color: #818cf8;
    letter-spacing: 1px;
  }

  .bio {
    font-size: 1.1rem;
    color: #cbd5e1;
    line-height: 1.7;
    max-width: 500px;
  }

  .action-links {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.8rem 1.8rem;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .primary-btn {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    color: white;
    box-shadow: 0 4px 15px rgba(79, 70, 229, 0.4);
  }

  .primary-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(79, 70, 229, 0.6);
  }

  .secondary-btn {
    background: rgba(255, 255, 255, 0.1);
    color: #f8fafc;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .secondary-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
  }

  .hero-image-wrapper {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    animation: fadeIn 1.5s ease-out forwards;
    opacity: 0;
    animation-delay: 0.3s;
  }

  .model-image {
    width: 250px;
    height: 350px;
    border-radius: 20px;
    background-image: url('/_DSC5126.png');
    background-size: cover;
    background-position: center;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .model-image::before {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 25px;
    border: 2px solid rgba(129, 140, 248, 0.3);
    z-index: -1;
  }

  @media (min-width: 768px) {
    .model-image {
      width: 350px;
      height: 480px;
    }
  }

  /* Animations */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>
