---
import Layout from '../layouts/Layout.astro';
---

<Layout title="刘扬 - 产品经理 / 创作者 / 独立开发者">
  <main class="hero-section">
    <div class="hero-container">
      <p class="hero-eyebrow">刘扬</p>
      <h1 class="hero-title">
        产品思维驱动，<br/>
        创造有价值的体验。
      </h1>
      <p class="hero-desc">
        汕头大学 · 网络与新媒体 · 专业排名第一<br/>
        致力于 AI 产品设计与内容创作，打造提升效率的学习工具。
      </p>

      <div class="hero-actions">
        <a href="/resume" class="btn-primary">查看简历 →</a>
        <a href="/showcase/videos" class="btn-secondary">视频作品 →</a>
      </div>
    </div>

    <!-- Bottom showcase cards -->
    <div class="showcase-strip">
      <a href="/showcase/videos" class="strip-card">
        <span class="strip-label">视频作品</span>
        <span class="strip-text">产品宣传视频、Demo 演示与创意内容</span>
      </a>
      <a href="/showcase/articles" class="strip-card">
        <span class="strip-label">发表文章</span>
        <span class="strip-text">北京日报、北青深一度等媒体发表报道</span>
      </a>
      <a href="https://wisdio.org" target="_blank" class="strip-card">
        <span class="strip-label">Wisdio</span>
        <span class="strip-text">基于 LLM 的视频学习浏览器插件</span>
      </a>
      <a href="/resume" class="strip-card">
        <span class="strip-label">个人简历</span>
        <span class="strip-text">产品实习生 / 用户研究实习生</span>
      </a>
    </div>
  </main>
</Layout>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 8rem 2rem 2rem;
  }

  .hero-container {
    text-align: center;
    max-width: 720px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .hero-eyebrow {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.5px;
    margin-bottom: 1.5rem;
    background: linear-gradient(to bottom, #fff 40%, rgba(255,255,255,0.5));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.8;
    margin-bottom: 2.5rem;
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary {
    padding: 0.7rem 1.5rem;
    background: #fff;
    color: #000;
    border-radius: 24px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    background: rgba(255, 255, 255, 0.85);
    transform: translateY(-1px);
  }

  .btn-secondary {
    padding: 0.7rem 1.5rem;
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    border-radius: 24px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    color: #fff;
  }

  /* Bottom strip cards */
  .showcase-strip {
    width: 100%;
    max-width: 1100px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.75rem;
    padding: 2rem 0;
  }

  .strip-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.2rem 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    transition: all 0.25s;
    cursor: pointer;
  }

  .strip-card:hover {
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.04);
  }

  .strip-label {
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
  }

  .strip-text {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.5;
  }
</style>
