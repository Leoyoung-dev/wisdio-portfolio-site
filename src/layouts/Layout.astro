---
interface Props {
	title?: string;
}

const { title = "刘扬" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
		<style is:global>
			*, *::before, *::after {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: 'Noto Serif SC', 'Source Serif 4', Georgia, 'Times New Roman', serif;
				background-color: #ffffff;
				color: #1a1a1a;
				line-height: 1.9;
				font-size: 16px;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			/* Navigation */
			.site-nav {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				z-index: 100;
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 1.5rem 3rem;
				background: rgba(255, 255, 255, 0.95);
				border-bottom: 1px solid #e0e0e0;
			}

			.site-nav .logo {
				font-size: 1.1rem;
				font-weight: 600;
				color: #1a1a1a;
				letter-spacing: 2px;
			}

			.site-nav .nav-links {
				display: flex;
				gap: 2.5rem;
				align-items: center;
				list-style: none;
			}

			.site-nav .nav-links a {
				font-size: 0.85rem;
				font-weight: 400;
				color: #666666;
				letter-spacing: 0.5px;
				transition: color 0.2s;
			}

			.site-nav .nav-links a:hover {
				color: #c9463d;
			}

			.site-nav .nav-cta {
				padding: 0.5rem 1.25rem;
				background: #1a1a1a;
				color: #fff !important;
				font-size: 0.8rem;
				font-weight: 500;
				letter-spacing: 1px;
				transition: all 0.2s;
			}

			.site-nav .nav-cta:hover {
				background: #333;
			}

			/* Utility */
			.page-body {
				padding-top: 70px;
			}

			/* Selection */
			::selection {
				background: rgba(201, 70, 61, 0.15);
			}

			/* Typography */
			h1, h2, h3, h4 {
				font-weight: 600;
				color: #1a1a1a;
			}

			p {
				margin-bottom: 1rem;
			}

			strong {
				font-weight: 600;
				color: #1a1a1a;
			}

			/* Responsive */
			@media (max-width: 768px) {
				.site-nav {
					padding: 1rem 1.5rem;
				}

				.site-nav .nav-links {
					gap: 1.5rem;
				}

				.site-nav .nav-links a {
					font-size: 0.8rem;
				}
			}

			@media (max-width: 480px) {
				.site-nav .logo {
					display: none;
				}
			}
		</style>
	</head>
	<body>
		<nav class="site-nav">
			<a href="/" class="logo">LIU YANG</a>
			<ul class="nav-links">
				<li><a href="/showcase/articles">作品集</a></li>
				<li><a href="/resume" class="nav-cta">简历</a></li>
			</ul>
		</nav>
		<slot />
	</body>
</html>